# --- データベース (SQLite / prisma ディレクトリからの相対パス) ---
DATABASE_URL="file:../data/thm.db"

# --- 管理コントロールパネル ---
ADMIN_PASSWORD="changeme"
# セッションCookie署名用 (未設定時はADMIN_PASSWORDから導出)
AUTH_SECRET=""

# --- 配信エンジン ---
# hls: ローカルHLSプレビュー (開発用) / rtmp: YouTubeへ実配信 / simulate: ffmpeg無しで進行のみ
STREAM_MODE="hls"
# STREAM_MODE=rtmp のとき必須
YOUTUBE_STREAM_KEY=""
# YouTubeチャンネルID (RTMP時に/watchでYouTube埋め込み表示用)
YOUTUBE_CHANNEL_ID=""

# --- ニコニコ動画ダウンロード用Cookie (yt-dlp --cookies) ---
NICO_COOKIES=""
# --- YouTube用Cookie (yt-dlp --cookies) ---
YT_COOKIES=""

# --- YouTube監視 ---
# 新着チェック間隔(秒)
YOUTUBE_POLL_INTERVAL_SEC="60"

# --- スケジューラ ---
# 番組表の先行生成時間(時間)
SCHEDULE_HORIZON_HOURS="24"
# 同一動画の再放送を禁止する日数
REPLAY_NG_DAYS="7"
